[
  {
    "code": 7000201,
    "name": "취약",
    "group": "Havoc",
    "type": "Core",
    "desc": "동일 실험체에게 기본 공격 또는 개별 스킬을 3회 적중 시 고정 피해를 추가로 입히며, 대상의 방어력을 감소시킵니다."
  },
  {
    "code": 7000401,
    "name": "흡혈마",
    "group": "Havoc",
    "type": "Core",
    "desc": "기본 공격 또는 개별 스킬로 실험체에게 피해를 입힐 때마다 모든 피해 흡혈과, 공격력 또는 스킬 증폭이 상승합니다. 최대 중첩 시 공격력 또는 스킬 증폭이 추가적으로 증가합니다."
  },
  {
    "code": 7000501,
    "name": "벽력",
    "group": "Havoc",
    "type": "Core",
    "desc": "적 실험체에게 스킬로 피해를 입혔을 때 스킬 피해를 입힙니다. 먼 거리에 있는 적에게 더 강한 피해를 입힙니다. 스킬이 적중한 적 실험체의 범위 내 가장 가까운 적 실험체가 있을 경우 전류의 줄기가 한 번 전이되어 스킬 피해를 입힙니다."
  },
  {
    "code": 7000601,
    "name": "아드레날린",
    "group": "Havoc",
    "type": "Core",
    "desc": "적 실험체에게 기본 공격으로 피해를 입힐 때마다 공격 속도가 증가합니다. 최대 중첩 시 추가적으로 공격 속도와 이동 속도가 증가합니다."
  },
  {
    "code": 7010101,
    "name": "철갑탄",
    "group": "Havoc",
    "type": "Sub",
    "desc": "방어 관통이 증가합니다."
  },
  {
    "code": 7010201,
    "name": "복수자",
    "group": "Havoc",
    "type": "Sub",
    "desc": "안전지대 활성화 단계 이후로 자신이 안전지대 안에 있을 때 적에게 입히는 피해가 증가합니다."
  },
  {
    "code": 7010301,
    "name": "수확",
    "group": "Havoc",
    "type": "Sub",
    "desc": "자신 또는 자신의 소환물이 입히는 모든 피해만큼 스태미나가 회복됩니다."
  },
  {
    "code": 7010401,
    "name": "갈증",
    "group": "Havoc",
    "type": "Sub",
    "desc": "자신 또는 자신의 소환물이 실험체가 아닌 대상에게 입히는 피해가 증가하며, 입힌 피해 일부의 체력이 회복됩니다"
  },
  {
    "code": 7010501,
    "name": "열세극복",
    "group": "Havoc",
    "type": "Sub",
    "desc": "대상 실험체의 최대 체력이 자신의 최대 체력보다 많은 경우 입히는 피해가 증가합니다."
  },
  {
    "code": 7010601,
    "name": "영혼 흡수 장치",
    "group": "Havoc",
    "type": "Sub",
    "desc": "적 실험체 처치 관여, 곰 및 보스 몬스터 처치 관여 시 중첩을 획득합니다. 중첩 당 공격력 또는 스킬 증폭이 증가합니다."
  },
  {
    "code": 7100101,
    "name": "금강",
    "group": "Fortification",
    "type": "Core",
    "desc": "상대 실험체를 이동 불가 상태로 만들면 방어력이 증가합니다. 방어력 증가 효과가 종료되는 즉시 주변에 스킬 피해를 입힙니다. 피해를 입은 대상은 이동 속도가 감소합니다."
  },
  {
    "code": 7100201,
    "name": "불괴",
    "group": "Fortification",
    "type": "Core",
    "desc": "무기 스킬 사용 시 일정 시간 동안 불괴 상태가 되며 받는 피해가 감소하고 방해 효과 저항력이 증가합니다."
  },
  {
    "code": 7100301,
    "name": "망각",
    "group": "Fortification",
    "type": "Core",
    "desc": "현재 체력이 낮을수록 기본 공격 피해를 덜 입습니다. 기본 공격 피해를 덜 입을 때마다 그 피해의 일부를 고유 피해로 반사합니다."
  },
  {
    "code": 7100401,
    "name": "빛의 수호",
    "group": "Fortification",
    "type": "Core",
    "desc": "최대 체력의 일정부분에 해당하는 보호막을 획득합니다. 보호막이 파괴되면 해로운 효과가 즉시 해제되며 이동 속도가 잠깐 증가합니다."
  },
  {
    "code": 7100501,
    "name": "응징",
    "group": "Fortification",
    "type": "Core",
    "desc": "적 실험체에 의해 잃은 체력에 비례하여 중첩을 획득합니다. 보유한 중첩에 비례해서 받는 피해가 감소합니다. 적에게 기본 공격을 가하면 보유한 중첩을 소모하여 스킬 피해를 주고 이동 속도를 감소시킵니다. 중첩을 소모하지 않고 일정 시간이 지나면 보유한 중첩에 비례하여 체력을 회복합니다."
  },
  {
    "code": 7110101,
    "name": "대담",
    "group": "Fortification",
    "type": "Sub",
    "desc": "스킬 또는 특성 의해 보호막이나 체력 회복 효과를 받으면 방어력이 증가합니다."
  },
  {
    "code": 7110201,
    "name": "특공대",
    "group": "Fortification",
    "type": "Sub",
    "desc": "주변에 아군이 없을 경우, 받는 피해가 감소합니다."
  },
  {
    "code": 7110301,
    "name": "둔감",
    "group": "Fortification",
    "type": "Sub",
    "desc": "치명타 피해를 받으면 받는 치명타 피해가 감소합니다."
  },
  {
    "code": 7110401,
    "name": "견고",
    "group": "Fortification",
    "type": "Sub",
    "desc": "방해 효과 저항이 증가합니다."
  },
  {
    "code": 7110501,
    "name": "중장갑",
    "group": "Fortification",
    "type": "Sub",
    "desc": "아이템으로 증가하는 피해 감소 옵션이 적용됩니다."
  },
  {
    "code": 7110601,
    "name": "먹보",
    "group": "Fortification",
    "type": "Sub",
    "desc": "음식 섭취에 걸리는 시간이 단축됩니다. 회복량이 낮은 음식 회복량이 증가합니다."
  },
  {
    "code": 7200101,
    "name": "초재생",
    "group": "Support",
    "type": "Core",
    "desc": "자신의 스킬 또는 특성에 의해 발생하는 모든 보호막 및 체력 회복량이 증가합니다. 자신에 의해 보호막 또는 체력 회복 효과를 받은 대상은 공격력 또는 스킬 증폭이 증가합니다."
  },
  {
    "code": 7200201,
    "name": "증폭 드론",
    "group": "Support",
    "type": "Core",
    "desc": "궁극기 사용 시 자신을 따라다니는 증폭 드론이 나타납니다. 증폭 드론은 주변 내 자신을 포함한 아군의 이동 속도와 스킬 피해량을 증가시킵니다."
  },
  {
    "code": 7200301,
    "name": "치유 드론",
    "group": "Support",
    "type": "Core",
    "desc": "자신을 포함한 아군 실험체의 체력이 일정 이하일 때 피해를 입은 경우, 자신을 따라다니는 치유 드론이 나타납니다. 치유 드론은 주변 내 자신을 포함한 아군의 체력을 매 초 잃은 체력의 일부를 회복시킵니다."
